# ── Local: copy this file to .env.local and fill values. Never commit .env.local.
#
# ── Vercel (required for farmer profile / MVP DB):
#   Dashboard → your project → Settings → Environment Variables
#   Add BOTH below for "Production" (and "Preview" if you use preview URLs).
#   Names must stay exactly VITE_* so Vite exposes them at build time.
#   Redeploy after saving (Deployments → ⋮ → Redeploy).
#
VITE_APP_ENV=development
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SOLANA_NETWORK=devnet
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_EXPLORER=https://explorer.solana.com
VITE_SOLANA_PROGRAM_ID=
# Legacy fallbacks (optional): VITE_SOLANA_CLUSTER, VITE_SOLANA_EXPLORER_BASE_URL
VITE_ELEVENLABS_API_KEY=
